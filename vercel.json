{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/audio/:path*",
      "destination": "/audio/:path*"
    },
    {
      "source": "/((?!api|audio|assets).*)",
      "destination": "/index.html"
    }
  ]
}
