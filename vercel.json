{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/audio/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|audio|assets|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
